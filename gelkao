#!/usr/bin/env bash
set -euo pipefail

here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib.sh
source "$here/lib.sh"

usage() {
  cat <<'EOF'
Usage:
  cat data/*.html | gelkao [-g "<project>"] <customer-number>   fetch invoices and audit
  cat data/*.html | gelkao list                                 list invoice UUIDs
  gelkao fetch <customer-number>                                download invoice CSVs (UUIDs on stdin)
  gelkao [-g "<project>"] audit [data_dir]                      build the DB from CSVs and audit

  -g "<project>"   audit only one Hetzner project (the invoice "grouping" column);
                   valid for the full run and audit only
  -q               skip the price-refresh prompt (non-interactive)
  HETZNER_CN       customer number (fallback for <customer-number>)
  DATA_DIR         CSV directory (default: data)
  DB               database path (default: <data_dir>/gelkao.db)
EOF
}

banner() {
  local b='' u='' r=''
  if [ -t 2 ]; then b=$'\e[1m'; u=$'\e[34m'; r=$'\e[0m'; fi
  printf '\n%sCloud Inefficiency Audit%s · %shttps://gelkao.com%s\n\n' "$b" "$r" "$u" "$r" >&2
}

cmd_list() { list_invoices "$@"; }

cmd_fetch() {
  local cn="${1:-${HETZNER_CN:-}}"
  [[ -n "$cn" ]] || die "customer number required (arg or HETZNER_CN env)"
  fetch_all "$cn" "${DATA_DIR:-data}"
}

cmd_audit() {
  local grouping=$1 quiet=$2; shift 2
  audit "$here" "${1:-${DATA_DIR:-data}}" "${DB:-}" "$grouping" "$quiet"
}

cmd_run() {
  local grouping=$1 quiet=$2; shift 2
  local cn="${1:-${HETZNER_CN:-}}"
  [[ -n "$cn" ]] || die "customer number required (arg or HETZNER_CN env)"
  banner
  run_pipeline "$here" "$cn" "${DATA_DIR:-data}" "${DB:-}" "$grouping" "$quiet"
}

main() {
  local OPTIND grouping="" quiet=0
  [[ "${1-}" = "--help" ]] && { usage; exit 0; }
  while getopts ":g:hq" opt; do
    case "$opt" in
      g) grouping=$OPTARG ;;
      q) quiet=1 ;;
      h) usage; exit 0 ;;
      :) die "option -$OPTARG requires a value" ;;
      \?) die "unknown option: -$OPTARG" ;;
    esac
  done
  shift $((OPTIND - 1))
  case "${1-}" in
    '')    usage; exit 2 ;;
    list)  shift; [[ -z "$grouping" ]] || die "-g is not valid for list";  cmd_list  "$@" ;;
    fetch) shift; [[ -z "$grouping" ]] || die "-g is not valid for fetch"; cmd_fetch "$@" ;;
    audit) shift; cmd_audit "$grouping" "$quiet" "$@" ;;
    *)            cmd_run   "$grouping" "$quiet" "$@" ;;
  esac
}

main "$@"
